# ── LLM ───────────────────────────────────────────────────────────────────────
# Set to FALSE for local dev with AI Studio key; TRUE for Cloud Run + Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your_google_ai_studio_key_here
GCP_PROJECT_ID=your_gcp_project_id
GCP_REGION=us-central1
GEMINI_MODEL=gemini-2.0-flash

# ── Image Generation ──────────────────────────────────────────────────────────
# Options: mock | vertexai | gemini | shortapi
IMAGE_GEN_PROVIDER=mock
IMAGEN_MODEL=imagen-3.0-generate-002
# Gemini native image gen (local with GOOGLE_API_KEY, cloud with Vertex AI creds)
GEMINI_IMAGE_MODEL=gemini-2.0-flash-exp-image-generation
# ShortAPI aggregated provider (supports Flux, DALL-E, SD, etc.)
SHORTAPI_API_KEY=your_shortapi_key
SHORTAPI_MODEL=flux-1.1-pro

# ── Trend Research ────────────────────────────────────────────────────────────
# Optional for local dev — if unset, trend tools return empty results gracefully
GOOGLE_CSE_API_KEY=your_google_custom_search_api_key
GOOGLE_CSE_ID=your_custom_search_engine_id
REDDIT_CLIENT_ID=your_reddit_app_client_id
REDDIT_CLIENT_SECRET=your_reddit_app_client_secret
REDDIT_USER_AGENT=ad-synth-ai/0.1

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change this to a strong random string in production
JWT_SECRET_KEY=dev-secret-change-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite for local dev; switch to postgresql+asyncpg://... for Cloud Run
DATABASE_URL=sqlite+aiosqlite:///./data/ad_synth.db
ADK_DATABASE_URL=sqlite+aiosqlite:///./data/adk_sessions.db

# ── Storage ───────────────────────────────────────────────────────────────────
# "local" stores uploads in data/uploads/; "gcs" stores in GCS bucket
STORAGE_BACKEND=local
GCS_BUCKET=your_gcs_bucket_name

# ── Observability ─────────────────────────────────────────────────────────────
# "json" = GCP Cloud Logging compatible structured logs; "text" = human-readable
LOG_LEVEL=INFO
LOG_FORMAT=json
